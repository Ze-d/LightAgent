{"id": "zoo_extract_keywords", "input": "Extract top keywords.", "expected_tool": "extract_keywords", "expected_args": {"text": "agent runtime agent eval tool", "top_k": 2}, "expected_result_contains": ["agent", "runtime"], "expected_answer_contains": ["done"]}
{"id": "zoo_regex_extract_codes", "input": "Extract ticket codes.", "expected_tool": "regex_extract", "expected_args": {"text": "IDs A-12 and B-34", "pattern": "[A-Z]-\\d+", "group": 0}, "expected_result_contains": ["A-12", "B-34"], "expected_answer_contains": ["done"]}
{"id": "zoo_regex_extract_group", "input": "Extract usernames.", "expected_tool": "regex_extract", "expected_args": {"text": "user:alice user:bob", "pattern": "user:(\\w+)", "group": 1}, "expected_result_contains": ["alice", "bob"], "expected_answer_contains": ["done"]}
{"id": "zoo_normalize_whitespace", "input": "Normalize repeated whitespace.", "expected_tool": "normalize_whitespace", "expected_args": {"text": "hello   world\nfrom\tagent"}, "expected_result_contains": ["hello world from agent"], "expected_answer_contains": ["done"]}
{"id": "zoo_json_path_read_nested", "input": "Read nested JSON path.", "expected_tool": "json_path_read", "expected_args": {"json_text": "{\"user\":{\"name\":\"Alice\",\"roles\":[\"admin\",\"dev\"]}}", "path": "user.roles.1"}, "expected_result_contains": ["dev"], "expected_answer_contains": ["done"]}
{"id": "zoo_json_path_read_missing", "input": "Read missing JSON path.", "expected_tool": "json_path_read", "expected_args": {"json_text": "{\"user\":{\"name\":\"Alice\"}}", "path": "user.email"}, "expected_result_contains": ["Path not found"], "expected_answer_contains": ["done"]}
{"id": "zoo_csv_summarize", "input": "Summarize CSV data.", "expected_tool": "csv_summarize", "expected_args": {"csv_text": "name,score\nalice,9\nbob,8"}, "expected_result_contains": ["\"columns\": 2", "\"data_rows\": 2", "name"], "expected_answer_contains": ["done"]}
{"id": "zoo_render_markdown_table", "input": "Render a markdown table.", "expected_tool": "render_markdown_table", "expected_args": {"headers": ["Name", "Score"], "rows": [["Alice", "9"], ["Bob", "8"]]}, "expected_result_contains": ["| Name | Score |", "| Alice | 9 |"], "expected_answer_contains": ["done"]}
{"id": "zoo_date_diff", "input": "Calculate date difference.", "expected_tool": "date_diff", "expected_args": {"start_date": "2026-05-01", "end_date": "2026-05-10"}, "expected_result_contains": ["9"], "expected_answer_contains": ["done"]}
{"id": "zoo_add_business_days", "input": "Add one business day to Friday.", "expected_tool": "add_business_days", "expected_args": {"start_date": "2026-05-15", "days": 1}, "expected_result_contains": ["2026-05-18"], "expected_answer_contains": ["done"]}
{"id": "zoo_add_business_days_zero", "input": "Add zero business days.", "expected_tool": "add_business_days", "expected_args": {"start_date": "2026-05-15", "days": 0}, "expected_result_contains": ["2026-05-15"], "expected_answer_contains": ["done"]}
{"id": "zoo_split_tasks", "input": "Split a task list.", "expected_tool": "split_tasks", "expected_args": {"text": "- write tests\n- run evals; update docs"}, "expected_result_contains": ["write tests", "run evals", "update docs"], "expected_answer_contains": ["done"]}
{"id": "zoo_prioritize_tasks", "input": "Prioritize urgent tasks.", "expected_tool": "prioritize_tasks", "expected_args": {"tasks": ["write docs", "urgent fix eval", "run tests"], "priority_keyword": "urgent"}, "expected_result_contains": ["urgent fix eval"], "expected_answer_contains": ["done"]}
{"id": "zoo_validate_url_valid", "input": "Validate a HTTPS URL.", "expected_tool": "validate_url", "expected_args": {"url": "https://example.com/path"}, "expected_result_contains": ["\"valid\": true", "\"scheme\": \"https\""], "expected_answer_contains": ["done"]}
{"id": "zoo_validate_url_invalid_scheme", "input": "Validate an FTP URL.", "expected_tool": "validate_url", "expected_args": {"url": "ftp://example.com/file"}, "expected_result_contains": ["\"valid\": false", "\"scheme\": \"ftp\""], "expected_answer_contains": ["done"]}
{"id": "zoo_hash_text_sha256", "input": "Hash text with SHA256.", "expected_tool": "hash_text", "expected_args": {"text": "agent", "algorithm": "sha256"}, "expected_result_contains": ["d4f0bc5a29de06b510f9aa428f1eedba926012b591fef7a518e776a7c9bd1824"], "expected_answer_contains": ["done"]}
{"id": "zoo_hash_text_md5", "input": "Hash text with MD5.", "expected_tool": "hash_text", "expected_args": {"text": "agent", "algorithm": "md5"}, "expected_result_contains": ["b33aed8f3134996703dc39f9a7c95783"], "expected_answer_contains": ["done"]}
{"id": "zoo_hash_text_unsupported", "input": "Hash text with an unsupported algorithm.", "expected_tool": "hash_text", "expected_args": {"text": "agent", "algorithm": "sha1"}, "expected_result_contains": ["Unsupported hash algorithm"], "expected_answer_contains": ["done"]}
{"id": "zoo_dedupe_lines_case_insensitive", "input": "Dedupe lines ignoring case.", "expected_tool": "dedupe_lines", "expected_args": {"text": "A\na\nB", "case_sensitive": false}, "expected_result_contains": ["A\nB"], "expected_answer_contains": ["done"]}
{"id": "zoo_dedupe_lines_case_sensitive", "input": "Dedupe lines with case sensitivity.", "expected_tool": "dedupe_lines", "expected_args": {"text": "A\na\nA", "case_sensitive": true}, "expected_result_contains": ["A\na"], "expected_answer_contains": ["done"]}
{"id": "zoo_sort_items_ascending", "input": "Sort items ascending.", "expected_tool": "sort_items", "expected_args": {"items": ["beta", "alpha", "gamma"], "reverse": false}, "expected_result_contains": ["alpha", "beta", "gamma"], "expected_answer_contains": ["done"]}
{"id": "zoo_sort_items_descending", "input": "Sort items descending.", "expected_tool": "sort_items", "expected_args": {"items": ["beta", "alpha", "gamma"], "reverse": true}, "expected_result_contains": ["gamma", "beta", "alpha"], "expected_answer_contains": ["done"]}
{"id": "zoo_template_render", "input": "Render a simple template.", "expected_tool": "template_render", "expected_args": {"template": "Hello {{name}}, score={{score}}", "values": {"name": "Alice", "score": 9}}, "expected_result_contains": ["Hello Alice, score=9"], "expected_answer_contains": ["done"]}
{"id": "zoo_template_render_missing_value", "input": "Render a template with a missing value.", "expected_tool": "template_render", "expected_args": {"template": "Hello {{name}} {{missing}}", "values": {"name": "Alice"}}, "expected_result_contains": ["Hello Alice {{missing}}"], "expected_answer_contains": ["done"]}
