# Copy this file to .env and fill in your values
LLM_API_KEY=your_api_key_here
LLM_MODEL_ID=qwen3.5-flash
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=30
MAX_STEPS=5

# Runtime state backend: memory or sqlite.
# sqlite persists chat sessions, context state, checkpoints, A2A tasks,
# and the A2A event replay log.
STATE_BACKEND=memory
STATE_DB_PATH=.runtime/myagent.sqlite3

# Public base URL advertised in /.well-known/agent-card.json
A2A_PUBLIC_URL=http://localhost:8000
A2A_AGENT_VERSION=0.1.0
A2A_DOCUMENTATION_URL=
A2A_ICON_URL=
# Set this to enable GET /a2a/v1/extendedAgentCard with bearer auth.
A2A_EXTENDED_CARD_TOKEN=
LOG_LEVEL=INFO
